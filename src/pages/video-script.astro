---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
---

<Layout title="短视频脚本生成">
  <Sidebar current="/video-script" />

  <main class="flex-1 lg:ml-64 mt-14 lg:mt-0 h-full flex flex-col overflow-hidden">
    <!-- Header -->
    <div class="shrink-0 px-4 sm:px-6 py-4 border-b border-gray-100 bg-white/60 backdrop-blur">
      <h1 class="text-lg font-bold text-gray-900 flex items-center gap-2">
        <span class="text-xl">🎬</span> 短视频脚本生成
      </h1>
      <p class="text-xs text-gray-400 mt-0.5">AI 生成分镜脚本，包含画面、口播、字幕和 BGM 建议</p>
    </div>

    <!-- Chat area -->
    <div id="chat-area" class="flex-1 overflow-y-auto scrollbar-thin px-4 sm:px-6 py-6">
      <div class="flex items-start gap-3 mb-6">
        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-500 to-indigo-500 flex items-center justify-center text-white text-xs shrink-0 shadow">🎬</div>
        <div class="bg-white rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm border border-gray-100 max-w-[85%]">
          <p class="text-sm text-gray-700">告诉我你的产品/主题，我来帮你写分镜脚本 🎥</p>
          <p class="text-xs text-gray-400 mt-1">支持种草、测评、教程、剧情等多种类型</p>
        </div>
      </div>
      <div id="result-container" class="hidden"></div>
    </div>

    <!-- Input area -->
    <div class="shrink-0 border-t border-gray-100 bg-white px-4 sm:px-6 py-4">
      <div class="max-w-3xl mx-auto space-y-3">
        <div class="flex gap-3">
          <div class="flex-1">
            <textarea id="topic" rows="2" placeholder="描述你的产品/主题，例如：便携式蓝牙音箱，主打户外防水..."
              class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm resize-none focus:border-purple-400 transition-all"></textarea>
          </div>
        </div>
        <div class="flex flex-wrap gap-3 items-end">
          <div class="flex gap-1.5">
            <label class="cursor-pointer">
              <input type="radio" name="duration" value="15秒" class="hidden peer" />
              <div class="peer-checked:border-purple-400 peer-checked:bg-purple-50 peer-checked:text-purple-700 border border-gray-200 rounded-lg px-2 py-1.5 text-xs font-medium transition-all">⚡ 15s</div>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="duration" value="30秒" class="hidden peer" checked />
              <div class="peer-checked:border-purple-400 peer-checked:bg-purple-50 peer-checked:text-purple-700 border border-gray-200 rounded-lg px-2 py-1.5 text-xs font-medium transition-all">🎯 30s</div>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="duration" value="60秒" class="hidden peer" />
              <div class="peer-checked:border-purple-400 peer-checked:bg-purple-50 peer-checked:text-purple-700 border border-gray-200 rounded-lg px-2 py-1.5 text-xs font-medium transition-all">🎬 60s</div>
            </label>
          </div>
          <div class="flex gap-1.5">
            <label class="cursor-pointer">
              <input type="radio" name="type" value="种草" class="hidden peer" checked />
              <div class="peer-checked:border-purple-400 peer-checked:bg-purple-50 peer-checked:text-purple-700 border border-gray-200 rounded-lg px-2 py-1.5 text-xs font-medium transition-all">🌱 种草</div>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="type" value="测评" class="hidden peer" />
              <div class="peer-checked:border-purple-400 peer-checked:bg-purple-50 peer-checked:text-purple-700 border border-gray-200 rounded-lg px-2 py-1.5 text-xs font-medium transition-all">📋 测评</div>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="type" value="教程" class="hidden peer" />
              <div class="peer-checked:border-purple-400 peer-checked:bg-purple-50 peer-checked:text-purple-700 border border-gray-200 rounded-lg px-2 py-1.5 text-xs font-medium transition-all">📖 教程</div>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="type" value="剧情" class="hidden peer" />
              <div class="peer-checked:border-purple-400 peer-checked:bg-purple-50 peer-checked:text-purple-700 border border-gray-200 rounded-lg px-2 py-1.5 text-xs font-medium transition-all">🎭 剧情</div>
            </label>
          </div>
          <button id="generate-btn"
            class="ml-auto px-5 py-2 bg-gradient-to-r from-purple-600 to-pink-500 text-white text-sm font-semibold rounded-xl shadow hover:shadow-lg hover:from-purple-700 hover:to-pink-600 transition-all active:scale-[0.97] disabled:opacity-50 disabled:cursor-not-allowed shrink-0">
            ✨ 生成脚本
          </button>
        </div>
      </div>
    </div>
  </main>

  <script type="module">
    import { streamChat, prompts } from '../utils/ai';

    var topicEl = document.getElementById('topic');
    var generateBtn = document.getElementById('generate-btn');
    var chatArea = document.getElementById('chat-area');
    var resultContainer = document.getElementById('result-container');

    var fullText = '';

    function escapeHtml(text) {
      var div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function scrollToBottom() {
      chatArea.scrollTop = chatArea.scrollHeight;
    }

    generateBtn.addEventListener('click', async function() {
      var topic = topicEl.value.trim();
      if (!topic) {
        topicEl.focus();
        topicEl.classList.add('border-red-300');
        setTimeout(function() { topicEl.classList.remove('border-red-300'); }, 2000);
        return;
      }

      var durationEl = document.querySelector('input[name="duration"]:checked');
      var typeEl = document.querySelector('input[name="type"]:checked');
      var duration = durationEl ? durationEl.value : '30秒';
      var type = typeEl ? typeEl.value : '种草';

      fullText = '';
      generateBtn.disabled = true;
      generateBtn.innerHTML = '<span class="loading-dots">生成中</span>';

      // User bubble
      var userBubble = document.createElement('div');
      userBubble.className = 'flex items-start gap-3 mb-4 justify-end';
      userBubble.innerHTML = '<div class="bg-purple-600 text-white rounded-2xl rounded-tr-sm px-4 py-3 shadow-sm max-w-[85%]">' +
        '<p class="text-sm">主题：' + escapeHtml(topic) + '</p>' +
        '<p class="text-xs opacity-80 mt-1">时长：' + escapeHtml(duration) + ' · 类型：' + escapeHtml(type) + '</p>' +
        '</div>' +
        '<div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center text-xs shrink-0">👤</div>';
      chatArea.insertBefore(userBubble, resultContainer);

      // AI bubble
      resultContainer.classList.remove('hidden');
      resultContainer.innerHTML = '<div class="flex items-start gap-3 mb-4">' +
        '<div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-500 to-indigo-500 flex items-center justify-center text-white text-xs shrink-0 shadow">🎬</div>' +
        '<div class="bg-white rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm border border-gray-100 max-w-[85%] min-w-[300px]">' +
        '<div class="flex items-center gap-2 text-purple-600"><span>✨</span><span class="loading-dots text-sm">正在编写脚本</span></div>' +
        '</div></div>';
      scrollToBottom();

      var messages = prompts.videoScript(topic, duration, type);

      await streamChat(messages, {
        onChunk: function(text) {
          fullText += text;
          var bubble = resultContainer.querySelector('.bg-white.rounded-2xl');
          if (bubble) {
            bubble.innerHTML = '<div class="prose-result text-sm text-gray-700 leading-relaxed whitespace-pre-wrap">' + escapeHtml(fullText) + '</div>';
          }
          scrollToBottom();
        },
        onDone: function() {
          generateBtn.disabled = false;
          generateBtn.innerHTML = '✨ 重新生成';
          var bubble = resultContainer.querySelector('.bg-white.rounded-2xl');
          if (bubble) {
            var copyBtn = document.createElement('button');
            copyBtn.className = 'mt-2 text-xs text-purple-600 hover:text-purple-700 font-medium px-2 py-1 rounded-lg hover:bg-purple-50 transition-all';
            copyBtn.textContent = '📋 复制脚本';
            copyBtn.addEventListener('click', function() {
              navigator.clipboard.writeText(fullText).then(function() {
                copyBtn.textContent = '✅ 已复制';
                setTimeout(function() { copyBtn.textContent = '📋 复制脚本'; }, 2000);
              });
            });
            bubble.appendChild(copyBtn);
          }
        },
        onError: function(err) {
          resultContainer.innerHTML = '<div class="flex items-start gap-3 mb-4">' +
            '<div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-500 to-indigo-500 flex items-center justify-center text-white text-xs shrink-0 shadow">🎬</div>' +
            '<div class="bg-red-50 rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm border border-red-100 max-w-[85%]">' +
            '<p class="text-sm text-red-600">' + escapeHtml(err) + '</p></div></div>';
          generateBtn.disabled = false;
          generateBtn.innerHTML = '✨ 生成脚本';
        },
      });
    });
  </script>
</Layout>
