---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="文案智能评分">
  <Navbar current="/scoring" />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
        <span class="text-3xl">📊</span> 文案智能评分
      </h1>
      <p class="text-gray-500 mt-1">多维度评分 + 专业改进建议，让文案更有转化力</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- 左侧输入区 -->
      <div class="space-y-5">
        <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
          <label class="block text-sm font-semibold text-gray-700 mb-2">文案内容 *</label>
          <textarea id="text-input" rows="10" placeholder="粘贴你要评分的文案内容..."
            class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm resize-none focus:border-purple-400 focus:ring-2 focus:ring-purple-100 transition-all"></textarea>
          <p class="text-xs text-gray-400 mt-2">支持任意长度的文案内容</p>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
          <label class="block text-sm font-semibold text-gray-700 mb-2">目标平台</label>
          <select id="platform-select"
            class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:border-purple-400 focus:ring-2 focus:ring-purple-100 transition-all bg-white">
            <option value="小红书">📕 小红书</option>
            <option value="公众号">💚 公众号</option>
            <option value="抖音">🎵 抖音</option>
            <option value="知乎">💙 知乎</option>
            <option value="视频号">📺 视频号</option>
            <option value="快手">🟡 快手</option>
            <option value="B站">📺 B站</option>
          </select>
        </div>

        <button id="score-btn"
          class="w-full py-4 bg-gradient-to-r from-purple-600 to-pink-500 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl hover:from-purple-700 hover:to-pink-600 transition-all active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed">
          📊 开始评分
        </button>
      </div>

      <!-- 右侧结果区 -->
      <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm min-h-[500px] flex flex-col">
        <div class="flex items-center justify-between mb-4">
          <h3 class="font-semibold text-gray-700">评分结果</h3>
          <button id="copy-btn" class="hidden text-sm text-purple-600 hover:text-purple-700 font-medium px-3 py-1 rounded-lg hover:bg-purple-50 transition-all">
            📋 复制报告
          </button>
        </div>
        <div id="result-area" class="flex-1 overflow-y-auto scrollbar-thin">
          <div class="flex flex-col items-center justify-center h-full text-gray-400">
            <span class="text-5xl mb-4">📊</span>
            <p class="text-sm">粘贴文案，选择平台</p>
            <p class="text-xs mt-1">AI 将从 5 个维度进行专业评分</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script type="module">
    import { streamChat, prompts } from '../utils/ai';

    const textInputEl = document.getElementById('text-input') as HTMLTextAreaElement;
    const platformSelectEl = document.getElementById('platform-select') as HTMLSelectElement;
    const scoreBtn = document.getElementById('score-btn') as HTMLButtonElement;
    const resultArea = document.getElementById('result-area') as HTMLDivElement;
    const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;

    let fullText = '';

    scoreBtn.addEventListener('click', async () => {
      const text = textInputEl.value.trim();
      if (!text) {
        textInputEl.focus();
        textInputEl.classList.add('border-red-300');
        setTimeout(() => textInputEl.classList.remove('border-red-300'), 2000);
        return;
      }

      const platform = platformSelectEl.value;

      fullText = '';
      scoreBtn.disabled = true;
      scoreBtn.innerHTML = '<span class="loading-dots">评分中</span>';
      copyBtn.classList.add('hidden');

      resultArea.innerHTML = '<div class="flex items-center gap-2 text-purple-600"><span class="text-xl">✨</span><span class="loading-dots">AI 正在评分</span></div>';

      const messages = prompts.scoring(text, platform);

      await streamChat(messages, {
        onChunk: (text) => {
          fullText += text;
          resultArea.innerHTML = `<div class="prose-result text-sm text-gray-700 leading-relaxed whitespace-pre-wrap">${escapeHtml(fullText)}</div>`;
          resultArea.scrollTop = resultArea.scrollHeight;
        },
        onDone: () => {
          scoreBtn.disabled = false;
          scoreBtn.innerHTML = '📊 重新评分';
          copyBtn.classList.remove('hidden');
        },
        onError: (err) => {
          resultArea.innerHTML = `<div class="text-red-500 text-sm p-4 bg-red-50 rounded-xl">${err}</div>`;
          scoreBtn.disabled = false;
          scoreBtn.innerHTML = '📊 开始评分';
        },
      });
    });

    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(fullText).then(() => {
        copyBtn.textContent = '✅ 已复制';
        setTimeout(() => { copyBtn.textContent = '📋 复制报告'; }, 2000);
      });
    });

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }
  </script>
</Layout>
