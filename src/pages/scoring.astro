---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
---

<Layout title="文案智能评分">
  <Sidebar current="/scoring" />

  <main class="flex-1 lg:ml-64 mt-14 lg:mt-0 h-full flex flex-col overflow-hidden">
    <!-- Header -->
    <div class="shrink-0 px-4 sm:px-6 py-4 border-b border-gray-100 bg-white/60 backdrop-blur">
      <h1 class="text-lg font-bold text-gray-900 flex items-center gap-2">
        <span class="text-xl">📊</span> 文案智能评分
      </h1>
      <p class="text-xs text-gray-400 mt-0.5">多维度评分 + 专业改进建议，让文案更有转化力</p>
    </div>

    <!-- Chat area -->
    <div id="chat-area" class="flex-1 overflow-y-auto scrollbar-thin px-4 sm:px-6 py-6">
      <div class="flex items-start gap-3 mb-6">
        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-500 to-teal-500 flex items-center justify-center text-white text-xs shrink-0 shadow">📊</div>
        <div class="bg-white rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm border border-gray-100 max-w-[85%]">
          <p class="text-sm text-gray-700">粘贴你的文案，我来帮你做专业评分 📈</p>
          <p class="text-xs text-gray-400 mt-1">从吸引力、可读性、平台适配度、转化力、原创感 5 个维度打分</p>
        </div>
      </div>
      <div id="result-container" class="hidden"></div>
    </div>

    <!-- Input area -->
    <div class="shrink-0 border-t border-gray-100 bg-white px-4 sm:px-6 py-4">
      <div class="max-w-3xl mx-auto space-y-3">
        <textarea id="text-input" rows="3" placeholder="粘贴你要评分的文案内容..."
          class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm resize-none focus:border-purple-400 transition-all"></textarea>
        <div class="flex gap-3 items-center">
          <select id="platform-select"
            class="px-3 py-2 border border-gray-200 rounded-lg text-sm focus:border-purple-400 transition-all bg-white">
            <option value="小红书">📕 小红书</option>
            <option value="公众号">💚 公众号</option>
            <option value="抖音">🎵 抖音</option>
            <option value="知乎">💙 知乎</option>
            <option value="视频号">📺 视频号</option>
            <option value="快手">🟡 快手</option>
            <option value="B站">📺 B站</option>
          </select>
          <button id="score-btn"
            class="ml-auto px-5 py-2 bg-gradient-to-r from-purple-600 to-pink-500 text-white text-sm font-semibold rounded-xl shadow hover:shadow-lg hover:from-purple-700 hover:to-pink-600 transition-all active:scale-[0.97] disabled:opacity-50 disabled:cursor-not-allowed shrink-0">
            📊 评分
          </button>
        </div>
      </div>
    </div>
  </main>

  <script type="module">
    import { streamChat, prompts } from '../utils/ai';

    var textInputEl = document.getElementById('text-input');
    var platformSelectEl = document.getElementById('platform-select');
    var scoreBtn = document.getElementById('score-btn');
    var chatArea = document.getElementById('chat-area');
    var resultContainer = document.getElementById('result-container');

    var fullText = '';

    function escapeHtml(text) {
      var div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function scrollToBottom() {
      chatArea.scrollTop = chatArea.scrollHeight;
    }

    scoreBtn.addEventListener('click', async function() {
      var text = textInputEl.value.trim();
      if (!text) {
        textInputEl.focus();
        textInputEl.classList.add('border-red-300');
        setTimeout(function() { textInputEl.classList.remove('border-red-300'); }, 2000);
        return;
      }

      var platform = platformSelectEl.value;

      fullText = '';
      scoreBtn.disabled = true;
      scoreBtn.innerHTML = '<span class="loading-dots">评分中</span>';

      // User bubble
      var userBubble = document.createElement('div');
      userBubble.className = 'flex items-start gap-3 mb-4 justify-end';
      userBubble.innerHTML = '<div class="bg-purple-600 text-white rounded-2xl rounded-tr-sm px-4 py-3 shadow-sm max-w-[85%]">' +
        '<p class="text-sm whitespace-pre-wrap">' + escapeHtml(text.substring(0, 200)) + (text.length > 200 ? '...' : '') + '</p>' +
        '<p class="text-xs opacity-80 mt-1">平台：' + escapeHtml(platform) + '</p>' +
        '</div>' +
        '<div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center text-xs shrink-0">👤</div>';
      chatArea.insertBefore(userBubble, resultContainer);

      // AI bubble
      resultContainer.classList.remove('hidden');
      resultContainer.innerHTML = '<div class="flex items-start gap-3 mb-4">' +
        '<div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-500 to-teal-500 flex items-center justify-center text-white text-xs shrink-0 shadow">📊</div>' +
        '<div class="bg-white rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm border border-gray-100 max-w-[85%] min-w-[300px]">' +
        '<div class="flex items-center gap-2 text-purple-600"><span>✨</span><span class="loading-dots text-sm">正在评分</span></div>' +
        '</div></div>';
      scrollToBottom();

      var messages = prompts.scoring(text, platform);

      await streamChat(messages, {
        onChunk: function(text) {
          fullText += text;
          var bubble = resultContainer.querySelector('.bg-white.rounded-2xl');
          if (bubble) {
            bubble.innerHTML = '<div class="prose-result text-sm text-gray-700 leading-relaxed whitespace-pre-wrap">' + escapeHtml(fullText) + '</div>';
          }
          scrollToBottom();
        },
        onDone: function() {
          scoreBtn.disabled = false;
          scoreBtn.innerHTML = '📊 重新评分';
          var bubble = resultContainer.querySelector('.bg-white.rounded-2xl');
          if (bubble) {
            var copyBtn = document.createElement('button');
            copyBtn.className = 'mt-2 text-xs text-purple-600 hover:text-purple-700 font-medium px-2 py-1 rounded-lg hover:bg-purple-50 transition-all';
            copyBtn.textContent = '📋 复制报告';
            copyBtn.addEventListener('click', function() {
              navigator.clipboard.writeText(fullText).then(function() {
                copyBtn.textContent = '✅ 已复制';
                setTimeout(function() { copyBtn.textContent = '📋 复制报告'; }, 2000);
              });
            });
            bubble.appendChild(copyBtn);
          }
        },
        onError: function(err) {
          resultContainer.innerHTML = '<div class="flex items-start gap-3 mb-4">' +
            '<div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-500 to-teal-500 flex items-center justify-center text-white text-xs shrink-0 shadow">📊</div>' +
            '<div class="bg-red-50 rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm border border-red-100 max-w-[85%]">' +
            '<p class="text-sm text-red-600">' + escapeHtml(err) + '</p></div></div>';
          scoreBtn.disabled = false;
          scoreBtn.innerHTML = '📊 评分';
        },
      });
    });
  </script>
</Layout>
