---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';

const tools = [
  { href: '/xiaohongshu', icon: '📕', title: '小红书笔记', desc: 'AI 生成爆款笔记，标题+正文+Hashtag 一步到位', gradient: 'from-red-400 to-pink-500' },
  { href: '/rewrite', icon: '🔄', title: '多平台改写', desc: '一次输入，多平台适配，风格差异明显', gradient: 'from-blue-400 to-purple-500' },
  { href: '/scoring', icon: '📊', title: '文案评分', desc: '多维度评分+专业改进建议', gradient: 'from-green-400 to-teal-500' },
  { href: '/sensitive', icon: '🔍', title: '违禁词检测', desc: '200+ 违禁词库，广告法+平台敏感词', gradient: 'from-orange-400 to-red-500' },
  { href: '/video-script', icon: '🎬', title: '视频脚本', desc: '分镜脚本+口播文案+BGM建议', gradient: 'from-purple-400 to-indigo-500' },
];
---

<Layout title="首页">
  <Sidebar current="/" />

  <!-- Main content area -->
  <main class="flex-1 lg:ml-64 mt-14 lg:mt-0 h-full overflow-y-auto scrollbar-thin">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8 lg:py-12">
      <!-- Welcome chat bubble -->
      <div class="flex items-start gap-3 mb-8 animate-fade-in">
        <div class="w-9 h-9 rounded-full bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center text-white text-sm shrink-0 shadow-lg">
          ✨
        </div>
        <div class="flex-1">
          <div class="bg-white rounded-2xl rounded-tl-sm px-5 py-4 shadow-sm border border-gray-100">
            <h1 class="text-xl font-bold text-gray-900 mb-2">你好！我是 AI 创作助手 👋</h1>
            <p class="text-gray-500 text-sm leading-relaxed">
              我可以帮你写小红书笔记、改写多平台文案、评分优化、检测违禁词、生成视频脚本。选择一个工具开始吧！
            </p>
          </div>
        </div>
      </div>

      <!-- Quick access cards -->
      <div class="space-y-3">
        {tools.map((tool, i) => (
          <a
            href={tool.href}
            class="chat-bubble flex items-center gap-4 bg-white rounded-2xl px-5 py-4 shadow-sm border border-gray-100 hover:shadow-md hover:border-purple-200 transition-all group"
            style={`animation-delay: ${i * 80}ms`}
          >
            <div class={`w-11 h-11 rounded-xl bg-gradient-to-br ${tool.gradient} flex items-center justify-center text-xl shadow-md shrink-0 group-hover:scale-105 transition-transform`}>
              {tool.icon}
            </div>
            <div class="min-w-0 flex-1">
              <h3 class="text-sm font-semibold text-gray-900 group-hover:text-purple-600 transition-colors">{tool.title}</h3>
              <p class="text-xs text-gray-400 truncate">{tool.desc}</p>
            </div>
            <svg class="w-4 h-4 text-gray-300 group-hover:text-purple-400 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        ))}
      </div>

      <!-- Stats -->
      <div class="mt-10 flex items-center justify-center gap-6 text-center animate-fade-in">
        <div>
          <p class="text-2xl font-bold gradient-text">5</p>
          <p class="text-xs text-gray-400">功能模块</p>
        </div>
        <div class="w-px h-8 bg-gray-200"></div>
        <div>
          <p class="text-2xl font-bold gradient-text">200+</p>
          <p class="text-xs text-gray-400">违禁词库</p>
        </div>
        <div class="w-px h-8 bg-gray-200"></div>
        <div>
          <p class="text-2xl font-bold gradient-text">7</p>
          <p class="text-xs text-gray-400">平台覆盖</p>
        </div>
      </div>
    </div>
  </main>
</Layout>
