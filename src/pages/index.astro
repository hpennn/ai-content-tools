---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const tools = [
  {
    href: '/xiaohongshu',
    icon: '📕',
    title: '小红书笔记创作',
    desc: 'AI 生成爆款笔记，标题 + 正文 + Hashtag 一步到位',
    tags: ['种草', '测评', '教程', '日常分享'],
    gradient: 'from-red-400 to-pink-500',
  },
  {
    href: '/rewrite',
    icon: '🔄',
    title: '多平台文案改写',
    desc: '一次输入，多平台适配，每个平台风格差异明显',
    tags: ['小红书', '公众号', '抖音', '知乎', 'B站'],
    gradient: 'from-blue-400 to-purple-500',
  },
  {
    href: '/scoring',
    icon: '📊',
    title: '文案智能评分',
    desc: '多维度评分 + 专业改进建议，让文案更有转化力',
    tags: ['吸引力', '可读性', '适配度', '转化力'],
    gradient: 'from-green-400 to-teal-500',
  },
  {
    href: '/sensitive',
    icon: '🔍',
    title: '违禁词检测',
    desc: '200+ 违禁词库，广告法 + 各平台敏感词全覆盖',
    tags: ['广告法', '小红书', '抖音', '公众号'],
    gradient: 'from-orange-400 to-red-500',
  },
  {
    href: '/video-script',
    icon: '🎬',
    title: '短视频脚本生成',
    desc: '分镜脚本 + 口播文案 + BGM 建议，拿来就能拍',
    tags: ['15s', '30s', '60s', '分镜表'],
    gradient: 'from-purple-400 to-indigo-500',
  },
];
---

<Layout title="首页">
  <Navbar current="/" />

  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-purple-600/5 via-transparent to-pink-600/5"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
      <div class="text-center animate-fade-in">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-6">
          <span class="gradient-text">AI 创作工具箱</span>
        </h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-4">
          一站式自媒体创作助手，覆盖小红书、公众号、抖音等全平台
        </p>
        <p class="text-gray-500 max-w-xl mx-auto">
          5 大功能模块 · AI 驱动 · 流式输出 · 即用即走
        </p>
      </div>
    </div>
  </section>

  <!-- Tools Grid -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {tools.map((tool, i) => (
        <a
          href={tool.href}
          class="card-hover group block rounded-2xl bg-white border border-gray-100 p-6 shadow-sm hover:shadow-xl"
          style={`animation-delay: ${i * 100}ms`}
        >
          <div class={`inline-flex items-center justify-center w-14 h-14 rounded-xl bg-gradient-to-br ${tool.gradient} text-2xl mb-4 shadow-lg`}>
            {tool.icon}
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-purple-600 transition-colors">
            {tool.title}
          </h3>
          <p class="text-gray-500 text-sm mb-4 leading-relaxed">
            {tool.desc}
          </p>
          <div class="flex flex-wrap gap-2">
            {tool.tags.map((tag) => (
              <span class="px-2 py-1 text-xs font-medium bg-purple-50 text-purple-600 rounded-full">
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-gray-100 py-8">
    <div class="max-w-7xl mx-auto px-4 text-center text-sm text-gray-400">
      <p>AI 创作工具箱 · Powered by 豆包大模型</p>
    </div>
  </footer>
</Layout>
