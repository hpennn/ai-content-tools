---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="小红书笔记创作">
  <Navbar current="/xiaohongshu" />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
        <span class="text-3xl">📕</span> 小红书笔记创作
      </h1>
      <p class="text-gray-500 mt-1">AI 帮你写出爆款小红书笔记，标题 + 正文 + Hashtag 一步到位</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- 左侧输入区 -->
      <div class="space-y-5">
        <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
          <label class="block text-sm font-semibold text-gray-700 mb-2">产品/主题描述 *</label>
          <textarea id="topic" rows="3" placeholder="例如：一款新的保湿面霜，含有玻尿酸和神经酰胺成分，质地轻薄不油腻，适合所有肤质"
            class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm resize-none focus:border-purple-400 focus:ring-2 focus:ring-purple-100 transition-all"></textarea>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
          <label class="block text-sm font-semibold text-gray-700 mb-2">关键词</label>
          <input id="keywords" type="text" placeholder="例如：保湿、面霜、干皮救星、秋冬护肤"
            class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:border-purple-400 focus:ring-2 focus:ring-purple-100 transition-all" />
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
          <label class="block text-sm font-semibold text-gray-700 mb-2">笔记风格</label>
          <div class="grid grid-cols-2 gap-3" id="style-options">
            <label class="cursor-pointer">
              <input type="radio" name="style" value="种草" checked class="hidden peer" />
              <div class="peer-checked:border-purple-400 peer-checked:bg-purple-50 peer-checked:text-purple-700 border border-gray-200 rounded-xl px-4 py-3 text-center text-sm font-medium transition-all hover:border-purple-300">
                🌱 种草推荐
              </div>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="style" value="测评" class="hidden peer" />
              <div class="peer-checked:border-purple-400 peer-checked:bg-purple-50 peer-checked:text-purple-700 border border-gray-200 rounded-xl px-4 py-3 text-center text-sm font-medium transition-all hover:border-purple-300">
                📋 真实测评
              </div>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="style" value="教程" class="hidden peer" />
              <div class="peer-checked:border-purple-400 peer-checked:bg-purple-50 peer-checked:text-purple-700 border border-gray-200 rounded-xl px-4 py-3 text-center text-sm font-medium transition-all hover:border-purple-300">
                📖 教程攻略
              </div>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="style" value="日常分享" class="hidden peer" />
              <div class="peer-checked:border-purple-400 peer-checked:bg-purple-50 peer-checked:text-purple-700 border border-gray-200 rounded-xl px-4 py-3 text-center text-sm font-medium transition-all hover:border-purple-300">
                💫 日常分享
              </div>
            </label>
          </div>
        </div>

        <button id="generate-btn"
          class="w-full py-4 bg-gradient-to-r from-purple-600 to-pink-500 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl hover:from-purple-700 hover:to-pink-600 transition-all active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed">
          ✨ 生成笔记
        </button>
      </div>

      <!-- 右侧结果区 -->
      <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm min-h-[500px] flex flex-col">
        <div class="flex items-center justify-between mb-4">
          <h3 class="font-semibold text-gray-700">生成结果</h3>
          <button id="copy-btn" class="hidden text-sm text-purple-600 hover:text-purple-700 font-medium px-3 py-1 rounded-lg hover:bg-purple-50 transition-all">
            📋 复制全部
          </button>
        </div>
        <div id="result-area" class="flex-1 overflow-y-auto scrollbar-thin">
          <div class="flex flex-col items-center justify-center h-full text-gray-400">
            <span class="text-5xl mb-4">📝</span>
            <p class="text-sm">填写左侧信息，点击生成按钮</p>
            <p class="text-xs mt-1">AI 将为你创作爆款小红书笔记</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script type="module">
    import { streamChat, prompts } from '../utils/ai';

    const topicEl = document.getElementById('topic') as HTMLTextAreaElement;
    const keywordsEl = document.getElementById('keywords') as HTMLInputElement;
    const generateBtn = document.getElementById('generate-btn') as HTMLButtonElement;
    const resultArea = document.getElementById('result-area') as HTMLDivElement;
    const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;

    let fullText = '';

    generateBtn.addEventListener('click', async () => {
      const topic = topicEl.value.trim();
      if (!topic) {
        topicEl.focus();
        topicEl.classList.add('border-red-300');
        setTimeout(() => topicEl.classList.remove('border-red-300'), 2000);
        return;
      }

      const keywords = keywordsEl.value.trim() || '无';
      const styleEl = document.querySelector('input[name="style"]:checked') as HTMLInputElement;
      const style = styleEl?.value || '种草';

      fullText = '';
      generateBtn.disabled = true;
      generateBtn.innerHTML = '<span class="loading-dots">生成中</span>';
      copyBtn.classList.add('hidden');

      resultArea.innerHTML = '<div class="flex items-center gap-2 text-purple-600"><span class="text-xl">✨</span><span class="loading-dots">AI 正在创作</span></div>';

      const messages = prompts.xiaohongshu(topic, keywords, style);

      await streamChat(messages, {
        onChunk: (text) => {
          fullText += text;
          resultArea.innerHTML = `<div class="prose-result text-sm text-gray-700 leading-relaxed whitespace-pre-wrap">${escapeHtml(fullText)}</div>`;
          resultArea.scrollTop = resultArea.scrollHeight;
        },
        onDone: () => {
          generateBtn.disabled = false;
          generateBtn.innerHTML = '✨ 重新生成';
          copyBtn.classList.remove('hidden');
        },
        onError: (err) => {
          resultArea.innerHTML = `<div class="text-red-500 text-sm p-4 bg-red-50 rounded-xl">${err}</div>`;
          generateBtn.disabled = false;
          generateBtn.innerHTML = '✨ 生成笔记';
        },
      });
    });

    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(fullText).then(() => {
        copyBtn.textContent = '✅ 已复制';
        setTimeout(() => { copyBtn.textContent = '📋 复制全部'; }, 2000);
      });
    });

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }
  </script>
</Layout>
