---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="违禁词检测">
  <Navbar current="/sensitive" />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
        <span class="text-3xl">🔍</span> 违禁词检测
      </h1>
      <p class="text-gray-500 mt-1">200+ 违禁词库，覆盖广告法违禁词 + 各平台敏感词，实时检测</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- 左侧输入区 -->
      <div class="space-y-5">
        <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
          <label class="block text-sm font-semibold text-gray-700 mb-2">文案内容 *</label>
          <textarea id="text-input" rows="10" placeholder="粘贴你的文案内容，点击检测按钮..."
            class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm resize-none focus:border-purple-400 focus:ring-2 focus:ring-purple-100 transition-all"></textarea>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
          <label class="block text-sm font-semibold text-gray-700 mb-2">检测平台</label>
          <select id="platform-select"
            class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm focus:border-purple-400 focus:ring-2 focus:ring-purple-100 transition-all bg-white">
            <option value="all">🌐 通用（全平台通用检测）</option>
            <option value="xiaohongshu">📕 小红书</option>
            <option value="douyin">🎵 抖音</option>
            <option value="gongzhonghao">💚 公众号</option>
          </select>
        </div>

        <button id="detect-btn"
          class="w-full py-4 bg-gradient-to-r from-purple-600 to-pink-500 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl hover:from-purple-700 hover:to-pink-600 transition-all active:scale-[0.98]">
          🔍 开始检测
        </button>
      </div>

      <!-- 右侧结果区 -->
      <div class="space-y-4">
        <!-- 统计卡片 -->
        <div id="stats-area" class="hidden">
          <div class="grid grid-cols-4 gap-3">
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
              <p class="text-2xl font-bold text-gray-900" id="stat-total">0</p>
              <p class="text-xs text-gray-500 mt-1">总计</p>
            </div>
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
              <p class="text-2xl font-bold text-red-500" id="stat-high">0</p>
              <p class="text-xs text-gray-500 mt-1">高危</p>
            </div>
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
              <p class="text-2xl font-bold text-orange-500" id="stat-medium">0</p>
              <p class="text-xs text-gray-500 mt-1">中危</p>
            </div>
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
              <p class="text-2xl font-bold text-yellow-500" id="stat-low">0</p>
              <p class="text-xs text-gray-500 mt-1">低危</p>
            </div>
          </div>
        </div>

        <!-- 标注结果 -->
        <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm min-h-[300px] flex flex-col">
          <h3 class="font-semibold text-gray-700 mb-4">检测结果</h3>
          <div id="result-area" class="flex-1 overflow-y-auto scrollbar-thin">
            <div class="flex flex-col items-center justify-center h-64 text-gray-400">
              <span class="text-5xl mb-4">🔍</span>
              <p class="text-sm">粘贴文案，点击检测按钮</p>
              <p class="text-xs mt-1">将自动标红违禁词并给出替换建议</p>
            </div>
          </div>
        </div>

        <!-- 违禁词详情列表 -->
        <div id="detail-area" class="hidden bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
          <h3 class="font-semibold text-gray-700 mb-4">违禁词详情</h3>
          <div id="detail-list" class="space-y-3 max-h-80 overflow-y-auto scrollbar-thin"></div>
        </div>
      </div>
    </div>
  </div>

  <script type="module">
    import { detectSensitiveWords } from '../utils/sensitive-words';

    const textInputEl = document.getElementById('text-input') as HTMLTextAreaElement;
    const platformSelectEl = document.getElementById('platform-select') as HTMLSelectElement;
    const detectBtn = document.getElementById('detect-btn') as HTMLButtonElement;
    const resultArea = document.getElementById('result-area') as HTMLDivElement;
    const statsArea = document.getElementById('stats-area') as HTMLDivElement;
    const detailArea = document.getElementById('detail-area') as HTMLDivElement;
    const detailList = document.getElementById('detail-list') as HTMLDivElement;

    detectBtn.addEventListener('click', () => {
      const text = textInputEl.value.trim();
      if (!text) {
        textInputEl.focus();
        textInputEl.classList.add('border-red-300');
        setTimeout(() => textInputEl.classList.remove('border-red-300'), 2000);
        return;
      }

      const platform = platformSelectEl.value;
      const results = detectSensitiveWords(text, platform);

      // 更新统计
      statsArea.classList.remove('hidden');
      document.getElementById('stat-total')!.textContent = String(results.length);
      document.getElementById('stat-high')!.textContent = String(results.filter(r => r.severity === 'high').length);
      document.getElementById('stat-medium')!.textContent = String(results.filter(r => r.severity === 'medium').length);
      document.getElementById('stat-low')!.textContent = String(results.filter(r => r.severity === 'low').length);

      // 标注文案
      if (results.length === 0) {
        resultArea.innerHTML = `
          <div class="flex flex-col items-center justify-center py-8 text-green-600">
            <span class="text-5xl mb-4">✅</span>
            <p class="font-medium">未检测到违禁词</p>
            <p class="text-sm text-gray-400 mt-1">文案安全，可以放心发布</p>
          </div>
        `;
        detailArea.classList.add('hidden');
        return;
      }

      // 高亮标注
      let highlighted = '';
      let lastIndex = 0;
      for (const item of results) {
        highlighted += escapeHtml(text.substring(lastIndex, item.index));
        const colorClass = item.severity === 'high' ? 'bg-red-100 text-red-700 border-red-200' :
                          item.severity === 'medium' ? 'bg-orange-100 text-orange-700 border-orange-200' :
                          'bg-yellow-100 text-yellow-700 border-yellow-200';
        highlighted += `<mark class="${colorClass} px-1 py-0.5 rounded border font-medium cursor-help" title="${item.category}: ${item.suggestion}">${escapeHtml(item.word)}</mark>`;
        lastIndex = item.index + item.word.length;
      }
      highlighted += escapeHtml(text.substring(lastIndex));

      resultArea.innerHTML = `<div class="text-sm text-gray-700 leading-relaxed whitespace-pre-wrap">${highlighted}</div>`;

      // 详情列表
      detailArea.classList.remove('hidden');
      detailList.innerHTML = results.map((item) => {
        const badgeClass = item.severity === 'high' ? 'bg-red-100 text-red-700' :
                          item.severity === 'medium' ? 'bg-orange-100 text-orange-700' :
                          'bg-yellow-100 text-yellow-700';
        const badgeText = item.severity === 'high' ? '高危' : item.severity === 'medium' ? '中危' : '低危';
        return `
          <div class="flex items-start gap-3 p-3 rounded-xl bg-gray-50 hover:bg-gray-100 transition-colors">
            <span class="px-2 py-0.5 text-xs font-medium rounded-full ${badgeClass}">${badgeText}</span>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="font-semibold text-gray-900">"${escapeHtml(item.word)}"</span>
                <span class="text-xs text-gray-400">${item.category}</span>
              </div>
              <p class="text-xs text-gray-500 mt-1">💡 建议：${item.suggestion}</p>
            </div>
          </div>
        `;
      }).join('');
    });

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }
  </script>
</Layout>
