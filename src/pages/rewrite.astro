---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="多平台文案改写">
  <Navbar current="/rewrite" />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
        <span class="text-3xl">🔄</span> 多平台文案改写
      </h1>
      <p class="text-gray-500 mt-1">一次输入，智能适配多个平台风格，每个版本差异明显</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- 左侧输入区 -->
      <div class="space-y-5">
        <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
          <label class="block text-sm font-semibold text-gray-700 mb-2">原始文案 *</label>
          <textarea id="original-text" rows="8" placeholder="粘贴你的原始文案内容..."
            class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm resize-none focus:border-purple-400 focus:ring-2 focus:ring-purple-100 transition-all"></textarea>
          <p class="text-xs text-gray-400 mt-2">支持任意格式的文案内容，AI 将自动理解并改写</p>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
          <label class="block text-sm font-semibold text-gray-700 mb-2">目标平台 * <span class="text-gray-400 font-normal">（可多选）</span></label>
          <div class="grid grid-cols-2 gap-3" id="platform-options">
            <label class="cursor-pointer">
              <input type="checkbox" value="小红书" class="hidden peer" checked />
              <div class="peer-checked:border-red-400 peer-checked:bg-red-50 peer-checked:text-red-700 border border-gray-200 rounded-xl px-3 py-2.5 text-center text-sm font-medium transition-all hover:border-red-300">
                📕 小红书
              </div>
            </label>
            <label class="cursor-pointer">
              <input type="checkbox" value="公众号" class="hidden peer" />
              <div class="peer-checked:border-green-400 peer-checked:bg-green-50 peer-checked:text-green-700 border border-gray-200 rounded-xl px-3 py-2.5 text-center text-sm font-medium transition-all hover:border-green-300">
                💚 公众号
              </div>
            </label>
            <label class="cursor-pointer">
              <input type="checkbox" value="抖音" class="hidden peer" />
              <div class="peer-checked:border-gray-800 peer-checked:bg-gray-100 peer-checked:text-gray-800 border border-gray-200 rounded-xl px-3 py-2.5 text-center text-sm font-medium transition-all hover:border-gray-400">
                🎵 抖音
              </div>
            </label>
            <label class="cursor-pointer">
              <input type="checkbox" value="知乎" class="hidden peer" />
              <div class="peer-checked:border-blue-400 peer-checked:bg-blue-50 peer-checked:text-blue-700 border border-gray-200 rounded-xl px-3 py-2.5 text-center text-sm font-medium transition-all hover:border-blue-300">
                💙 知乎
              </div>
            </label>
            <label class="cursor-pointer">
              <input type="checkbox" value="视频号" class="hidden peer" />
              <div class="peer-checked:border-orange-400 peer-checked:bg-orange-50 peer-checked:text-orange-700 border border-gray-200 rounded-xl px-3 py-2.5 text-center text-sm font-medium transition-all hover:border-orange-300">
                📺 视频号
              </div>
            </label>
            <label class="cursor-pointer">
              <input type="checkbox" value="快手" class="hidden peer" />
              <div class="peer-checked:border-yellow-500 peer-checked:bg-yellow-50 peer-checked:text-yellow-700 border border-gray-200 rounded-xl px-3 py-2.5 text-center text-sm font-medium transition-all hover:border-yellow-400">
                🟡 快手
              </div>
            </label>
            <label class="cursor-pointer">
              <input type="checkbox" value="B站" class="hidden peer" />
              <div class="peer-checked:border-cyan-400 peer-checked:bg-cyan-50 peer-checked:text-cyan-700 border border-gray-200 rounded-xl px-3 py-2.5 text-center text-sm font-medium transition-all hover:border-cyan-300">
                📺 B站
              </div>
            </label>
          </div>
        </div>

        <button id="generate-btn"
          class="w-full py-4 bg-gradient-to-r from-purple-600 to-pink-500 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl hover:from-purple-700 hover:to-pink-600 transition-all active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed">
          ✨ 开始改写
        </button>
      </div>

      <!-- 右侧结果区 -->
      <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm min-h-[500px] flex flex-col">
        <div class="flex items-center justify-between mb-4">
          <h3 class="font-semibold text-gray-700">改写结果</h3>
          <button id="copy-btn" class="hidden text-sm text-purple-600 hover:text-purple-700 font-medium px-3 py-1 rounded-lg hover:bg-purple-50 transition-all">
            📋 复制全部
          </button>
        </div>
        <div id="result-area" class="flex-1 overflow-y-auto scrollbar-thin">
          <div class="flex flex-col items-center justify-center h-full text-gray-400">
            <span class="text-5xl mb-4">🔄</span>
            <p class="text-sm">输入原始文案，选择目标平台</p>
            <p class="text-xs mt-1">AI 将生成多平台适配版本</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline type="module">
    import { streamChat, prompts } from '../utils/ai';

    const originalTextEl = document.getElementById('original-text') as HTMLTextAreaElement;
    const generateBtn = document.getElementById('generate-btn') as HTMLButtonElement;
    const resultArea = document.getElementById('result-area') as HTMLDivElement;
    const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;

    let fullText = '';

    generateBtn.addEventListener('click', async () => {
      const originalText = originalTextEl.value.trim();
      if (!originalText) {
        originalTextEl.focus();
        originalTextEl.classList.add('border-red-300');
        setTimeout(() => originalTextEl.classList.remove('border-red-300'), 2000);
        return;
      }

      const checkboxes = document.querySelectorAll('#platform-options input[type="checkbox"]:checked') as NodeListOf<HTMLInputElement>;
      const platforms = Array.from(checkboxes).map(cb => cb.value);
      if (platforms.length === 0) {
        alert('请至少选择一个目标平台');
        return;
      }

      fullText = '';
      generateBtn.disabled = true;
      generateBtn.innerHTML = '<span class="loading-dots">改写中</span>';
      copyBtn.classList.add('hidden');

      resultArea.innerHTML = '<div class="flex items-center gap-2 text-purple-600"><span class="text-xl">✨</span><span class="loading-dots">AI 正在改写</span></div>';

      const messages = prompts.rewrite(originalText, platforms);

      await streamChat(messages, {
        onChunk: (text) => {
          fullText += text;
          resultArea.innerHTML = `<div class="prose-result text-sm text-gray-700 leading-relaxed whitespace-pre-wrap">${escapeHtml(fullText)}</div>`;
          resultArea.scrollTop = resultArea.scrollHeight;
        },
        onDone: () => {
          generateBtn.disabled = false;
          generateBtn.innerHTML = '✨ 重新改写';
          copyBtn.classList.remove('hidden');
        },
        onError: (err) => {
          resultArea.innerHTML = `<div class="text-red-500 text-sm p-4 bg-red-50 rounded-xl">${err}</div>`;
          generateBtn.disabled = false;
          generateBtn.innerHTML = '✨ 开始改写';
        },
      });
    });

    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(fullText).then(() => {
        copyBtn.textContent = '✅ 已复制';
        setTimeout(() => { copyBtn.textContent = '📋 复制全部'; }, 2000);
      });
    });

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }
  </script>
</Layout>
